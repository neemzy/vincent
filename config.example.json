{
  "httpPort": 8666,
  "wadDir": "/path/to/wads",

  "ports": {
    "uzdoom": {
      "path": "/path/to/uzdoom",
      "compLevels": {
        "default": "",
        "mbf21": [
          "+set compatmode 9",
          "\"+set compatflags -1785091888\"",
          "+set compatflags2 13064"
        ],
        "mbf": [
          "+set compatmode 7",
          "\"+set compatflags -1786140464\"",
          "+set compatflags2 29448"
        ],
        "boom": [
          "+set compatmode 6",
          "\"+set compatflags -1878415152\"",
          "+set compatflags2 16904"
        ],
        "vanilla": [
          "+set compatmode 2",
          "\"+set compatflags -1172751401\"",
          "+set compatflags2 49675"
        ]
      }
    },
    "dsda": {
      "path": "/path/to/dsda-doom",
      "compLevels": {
        "mbf21": "-complevel 21",
        "mbf": "-complevel 11",
        "boom": "-complevel 9",
        "vanilla_doom2": "-complevel 2",
        "vanilla_udoom": "-complevel 3",
        "vanilla_final": "-complevel 4"
      }
    },
    "woof": {
      "path": "/path/to/woof",
      "setupPath": "/path/to/woof-setup",
      "compLevels": {
        "mbf21": "-complevel mbf21",
        "mbf": "-complevel mbf",
        "boom": "-complevel boom",
        "vanilla": "-complevel vanilla",
        "vanilla_doom2": "-complevel vanilla -gameversion 1.9",
        "vanilla_udoom": "-complevel vanilla -gameversion ultimate",
        "vanilla_final": "-complevel vanilla -gameversion final"
      }
    },
    "crispy": {
      "path": "/path/to/crispy-doom",
      "setupPath": "/path/to/crispy-doom-setup",
      "compLevels": {
        "vanilla": "",
        "vanilla_doom2": "-gameversion 1.9",
        "vanilla_udoom": "-gameversion ultimate",
        "vanilla_final": "-gameversion final"
      }
    }
  },

  "profiles": [
    {
      "title": "Crispy Doom",
      "port": "crispy"
    },
    {
      "title": "Woof!",
      "port": "woof"
    },
    {
      "title": "DSDA Doom",
      "port": "dsda"
    },
    {
      "title": "UZDoom",
      "port": "uzdoom"
    },
    {
      "title": "UZDoom (no freelook)",
      "port": "uzdoom",
      "params": "+set dmflags 262144"
    }
  ]
}
